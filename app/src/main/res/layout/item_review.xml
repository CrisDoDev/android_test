<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="12dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/txtReviewUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nguyễn Văn A"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtReviewDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="20/06/2026"
            android:textColor="#666666"
            android:textSize="12sp" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/layoutStarsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="4dp"
        android:orientation="horizontal">
        <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/btn_star_big_on" app:tint="#FFC107"/>
        <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/btn_star_big_on" app:tint="#FFC107"/>
        <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/btn_star_big_on" app:tint="#FFC107"/>
        <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/btn_star_big_on" app:tint="#FFC107"/>
        <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/btn_star_big_on" app:tint="#FFC107"/>
    </LinearLayout>

    <TextView
        android:id="@+id/txtReviewComment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trà sữa ngon, giao hàng nhanh, trân châu mềm dẻo đúng vị mình thích!"
        android:textColor="#1A1A1A"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/layoutAdminReplyContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:background="#F5F5F5"
        android:orientation="vertical"
        android:padding="10dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phản hồi từ Cửa hàng"
                android:textColor="#2D937F"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtAdminRepliedAt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="21/06/2026"
                android:textColor="#666666"
                android:textSize="11sp" />
        </RelativeLayout>

        <TextView
            android:id="@+id/txtAdminReplyContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cảm ơn bạn đã ủng hộ quán! Rất mong được phục vụ bạn trong những đơn hàng tiếp theo ạ."
            android:textColor="#1A1A1A"
            android:textSize="12sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="12dp"
        android:background="#666666"
        android:alpha="0.2"/>
</LinearLayout>